#!/bin/sh

mkdir -p /proc /sys /tmp /run /dev/pts
mount -t devtmpfs devtmpfs /dev 2>/dev/null || {
	mknod /dev/console c 5 1 2>/dev/null || true
	mknod /dev/ttyS0 c 4 64 2>/dev/null || true
}

for tty in /dev/console /dev/ttyS0 /dev/hvc0; do
	[ -c "$tty" ] && exec <"$tty" >"$tty" 2>&1 && break
done

mount -t proc proc /proc 2>/dev/null || true
mount -t sysfs sysfs /sys 2>/dev/null || true
mount -t tmpfs tmpfs /tmp 2>/dev/null || true
mount -t devpts devpts /dev/pts 2>/dev/null || true

echo
echo "=== ESP32-S31 BusyBox initramfs ==="
echo "Type 'help' for BusyBox applets."

exec /bin/cttyhack /bin/sh -i
